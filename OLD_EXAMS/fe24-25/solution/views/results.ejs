<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Quiz results</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="container">
    <div class="header">
      <h1>Quiz completed</h1>
    </div>

    <div class="main">
      <div class="results-card">
        <h2><%= quiz.title %></h2>

        <div class="score-display">
          <div class="score-text">
            <%= correctAnswers %>/<%= totalQuestions %> correct answers (<%= percentage %>%)
          </div>
        </div>

        <div class="actions">
          <a class="btn-secondary" href="/">Back to home</a>
          <a class="btn-primary" href="/quiz/start">Try again</a>
        </div>
      </div>
    </div>
  </div>
</body>
</html>
